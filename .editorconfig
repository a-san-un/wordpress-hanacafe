# EditorConfig: https://editorconfig.org
# .prettierrc / .php-cs-fixer.php と完全同期
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JS / SCSS / JSON / YAML / MD — Prettier 管理（スペース2）
[*.{js,scss,json,yml,yaml,md}]
indent_style = space
indent_size = 2

# PHP — PHP CS Fixer 管理（タブ）
[*.php]
indent_style = tab
